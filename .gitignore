# Secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.key

# Codex CLI local config — holds a RENDER_API_KEY in config.toml; never commit
.codex/

# Node
node_modules/
.pnpm-store/
dist/
build/
coverage/
*.tsbuildinfo

# Supabase CLI
db/supabase/.branches/
db/supabase/.temp/
db/supabase/.env

# Local DB backups — never commit (use the automated off-platform backup)
*_backup_*.sql

# Generated artifacts -- COMMITTED. CI regenerates and runs `git diff --exit-code`
# against the committed copies; the diff is the contract-drift check the brief
# requires ("SDK builds from the spec with no drift").
#   openapi/openapi.json       (emitted from api/ zod schemas)
#   sdk/src/generated/types.ts (emitted from openapi/openapi.json)
# Build artefacts that ARE ignored:
sdk/dist/

# Editors / OS
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code per-project state
.claude/
.agents/
