{
  "name": "@rentalcrm/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Postgres schema, RLS policies, triggers, and seeds. Source of truth for the data spine.",
  "scripts": {
    "migrate:new": "supabase migration new",
    "migrate:up": "supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "migrate:reset": "supabase db reset --db-url \"$SUPABASE_DB_URL\"",
    "test:isolation": "tsx test/isolation.test.ts",
    "test:audit": "tsx test/audit.test.ts",
    "test:chain-mixed-era": "tsx test/chain-mixed-era.test.ts",
    "test:money": "tsx test/money.test.ts",
    "test:tenancy-status": "tsx test/tenancy-status.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bench:rls": "tsx test/bench-rls.ts"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
