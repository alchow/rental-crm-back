# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase: API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase: Auth — JWKS (ES256). Optional; derived from SUPABASE_URL by default.
# Override only when you have a non-standard deployment.
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
# SUPABASE_JWT_AUDIENCE=authenticated

# Supabase: Database (used by `supabase` CLI for migrations)
SUPABASE_DB_URL=

# Local API service
PORT=8787
NODE_ENV=development
