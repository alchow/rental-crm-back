# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase: API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase: Auth — HS256 verification (set in api/src/env.ts)
SUPABASE_JWT_SECRET=

# Supabase: Database (used by `supabase` CLI for migrations)
SUPABASE_DB_URL=

# Local API service
PORT=8787
NODE_ENV=development
