# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase: API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase: Auth — JWKS (ES256). Optional; derived from SUPABASE_URL by default.
# Override only when you have a non-standard deployment.
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
# SUPABASE_JWT_AUDIENCE=authenticated

# Supabase: Database. Used by the `supabase` CLI for migrations AND by the
# onboarding-import executor's transactional preview/commit (raw pg connection,
# api/src/admin/db-pool.ts). This is a direct-Postgres credential and is MORE
# powerful than the service-role key -- treat it as a top-tier secret and guard
# it like SUPABASE_SERVICE_ROLE_KEY (never expose it client-side).
#
# Provision a DEDICATED least-privilege login role for it: NOT a superuser, with
# only the grants the import needs, and able to `SET ROLE service_role` (which
# the executor does per-transaction so writes bypass RLS while audit.actor
# attribution still applies). Do not reuse a broad admin/superuser login here.
#
# ⚠️ In LOCAL DEV (.env.local) this MUST be your local supabase db, e.g.
#   postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   (from `supabase status --workdir db` -> DB_URL).
# The PROD value belongs ONLY in Render's environment. `migrate:reset` refuses
# to run against a non-local URL (scripts/assert-local-db.sh) so a prod value
# here can't drop the database; deliberate prod migrations go through the
# guarded scripts/apply-*-migration.sh (which use SUPABASE_DB_URL_PROD).
SUPABASE_DB_URL=

# Backups: BACKUP_DB_URL exists ONLY as a GitHub Actions repo secret (never in
# .env.local or Render). It is a direct/session-pooler connection for the
# dedicated read-only `backup_reader` role used by the scheduled pg_dump
# workflows (.github/workflows/db-backup-*.yml). Do NOT reuse SUPABASE_DB_URL
# for it -- that role is least-privilege for imports, not read-all. Setup and
# restore procedures: docs/backup-recovery-runbook.md.

# Anthropic API key — onboarding-import recognition/mapping LLM. Only column
# names + <=5 sample values per column are ever sent; never full row data.
ANTHROPIC_API_KEY=

# Parent domain for per-account branded reply subdomains (e.g. mail.example.com).
# When set AND an account has an email_subdomain, new email threads mint their
# tokenized reply addresses under <subdomain>.<parent> (t-…@acme.mail.example.com)
# instead of the shared EMAIL_REPLY_DOMAIN. Unset -> branded minting is off
# platform-wide and accounts fall back to EMAIL_REPLY_DOMAIN. Inbound mail for
# every branded subdomain must route to the transport's webhook (ops).
# EMAIL_PLATFORM_PARENT_DOMAIN=mail.example.com

# Local API service
PORT=8787
NODE_ENV=development

# Structured logging (pino). JSON lines in production, pretty-printed in
# development. One of: fatal | error | warn | info | debug | trace.
# /healthz request lines are logged at debug to keep poll noise out of info.
# LOG_LEVEL=info

# Browser origins allowed to call the API via CORS, beyond the built-in
# Lovable defaults (*.lovableproject.com, *.lovable.app). Comma-separated;
# each entry is an exact origin or a *.example.com wildcard pattern.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# Public origin of the FRONTEND app. Core builds tenant condition-form capture
# links off it (<APP_BASE_URL>/inventory/<secret>) and emails them out, so it must
# be the host that serves that page -- NOT this API's own URL. In production it
# is the same origin you list in CORS_ALLOWED_ORIGINS, e.g.
#   APP_BASE_URL=https://rentalnotesagent.onrender.com
# Unset -> links fall back to the dead host https://app.example (logged as a
# warning). Fine locally; a silently unopenable link in production.
# APP_BASE_URL=http://localhost:5173
