{
  "name": "rental-crm-back",
  "version": "0.0.0",
  "private": true,
  "description": "Landlord CRM backend — records-as-evidence; API-first.",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --parallel typecheck",
    "build": "pnpm -r --filter=./api --filter=./sdk --filter=./cli build",
    "dev": "pnpm --filter ./api dev",
    "lint:service-role": "bash scripts/lint-service-role.sh",
    "lint:admin-quarantine": "bash scripts/test-admin-quarantine.sh",
    "check:render-env": "node scripts/check-render-env-drift.mjs",
    "check:drift": "bash scripts/check-contract-drift.sh",
    "check:guide-drift": "tsx scripts/check-guide-drift.ts",
    "check:test-manifest": "node scripts/check-test-manifest.mjs",
    "check:source-size": "node scripts/check-source-size.mjs",
    "db:generate": "bash scripts/generate-db-artifacts.sh",
    "check:db-generated": "bash scripts/generate-db-artifacts.sh --check",
    "db:migration:new": "node scripts/new-migration.mjs",
    "secrets:scan": "gitleaks git --staged --no-banner --redact -v",
    "secrets:scan-all": "gitleaks git . --no-banner --redact -v",
    "check:static": "pnpm lint && pnpm typecheck && pnpm lint:service-role && pnpm lint:admin-quarantine && pnpm check:render-env && pnpm check:drift && pnpm check:guide-drift && pnpm check:test-manifest && pnpm check:source-size",
    "check:fast": "pnpm check:static && pnpm --filter ./api test:unit && pnpm --filter ./api build",
    "check": "pnpm check:fast",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  }
}
