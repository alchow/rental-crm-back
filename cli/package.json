{
  "name": "@rentalcrm/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Reference CLI that walks the full end-to-end flow against /v1 using only the generated SDK.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "walk": "tsx src/index.ts"
  },
  "dependencies": {
    "@rentalcrm/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0"
  }
}
