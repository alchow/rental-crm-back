{
  "name": "@rentalcrm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../.env.local src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup && node scripts/copy-static.mjs && node test/bundle-static-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:api-isolation": "tsx test/api-isolation.test.ts",
    "test:profile": "tsx test/profile.test.ts",
    "test:search": "tsx test/search.test.ts",
    "test:intake": "tsx test/intake.test.ts",
    "test:attachments": "tsx test/attachments.test.ts",
    "test:documents": "tsx test/documents.test.ts",
    "test:condition-reports": "tsx test/condition-reports.test.ts",
    "test:area-inspection-layouts": "tsx test/area-inspection-layouts.test.ts",
    "test:phase9": "tsx test/phase9.test.ts",
    "test:auto-charge": "tsx test/auto-charge.test.ts",
    "test:rent-changes": "tsx test/rent-changes.test.ts",
    "test:phase10": "tsx test/phase10.test.ts",
    "test:phase11": "tsx test/phase11.test.ts",
    "test:phase12": "tsx test/phase12.test.ts",
    "test:imports": "tsx test/imports.test.ts",
    "test:ledger": "tsx test/ledger.test.ts",
    "test:rent-rollup": "tsx test/rent-rollup.test.ts",
    "test:tenancy-start-date": "tsx test/tenancy-start-date.test.ts",
    "test:tenancy-endings": "tsx test/tenancy-endings.test.ts",
    "test:tenant-email-uniqueness": "tsx test/tenant-email-uniqueness.test.ts",
    "test:tenant-phone-e164": "tsx test/tenant-phone-e164.test.ts",
    "test:multi-status-filters": "tsx test/multi-status-filters.test.ts",
    "test:maintenance-reporter": "tsx test/maintenance-reporter.test.ts",
    "test:interactions-journal": "tsx test/interactions-journal.test.ts",
    "test:interactions-participants": "tsx test/interactions-participants.test.ts",
    "test:comms": "tsx test/comms.test.ts",
    "test:comms-group": "tsx test/comms-group.test.ts",
    "test:comms-platform-numbers": "tsx test/comms-platform-numbers.test.ts",
    "test:comms-email": "tsx test/comms-email.test.ts",
    "test:comms-email-threads": "tsx test/comms-email-threads.test.ts",
    "test:accounts-branding": "tsx test/accounts-branding.test.ts",
    "test:auth-refresh": "tsx test/auth-refresh.test.ts",
    "test:comms-persona-resolve": "tsx test/comms-persona-resolve.test.ts",
    "test:comms-persona": "tsx test/comms-persona.test.ts",
    "test:comms-persona-usecases": "tsx test/comms-persona-usecases.test.ts",
    "test:comms-evidence": "tsx test/comms-evidence.test.ts",
    "retention:evidence": "tsx src/admin/run-evidence-retention.ts",
    "janitors:maintenance": "tsx src/admin/run-maintenance-janitors.ts",
    "charges:generate": "tsx src/admin/run-rent-charges.ts",
    "test:events-feed": "tsx test/events-feed.test.ts",
    "test:agent-principal": "tsx test/agent-principal.test.ts",
    "test:agent-grants": "tsx test/agent-grants.test.ts",
    "test:agent-tokens": "tsx test/agent-tokens.test.ts",
    "test:agent-membership-divergence": "tsx test/agent-membership-divergence.test.ts",
    "test:imports-live": "tsx test/imports-live.test.ts",
    "bench:import": "tsx test/bench-import.ts",
    "test:unit": "vitest run",
    "ci:integration": "node test/run-test-group.mjs integration"
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/admin/document-templates.ts"
    ],
    "format": [
      "esm"
    ],
    "platform": "node",
    "target": "node22",
    "sourcemap": true,
    "clean": true
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.0",
    "@supabase/supabase-js": "^2.46.1",
    "csv-parse": "^6.2.1",
    "hono": "^4.6.10",
    "jose": "^5.10.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "sharp": "^0.33.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@rentalcrm/sdk": "workspace:*",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^11.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "vitest": "^2.1.9"
  }
}
