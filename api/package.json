    "test:phase11": "tsx test/phase11.test.ts"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.0",
    "@supabase/supabase-js": "^2.46.1",
    "hono": "^4.6.10",
    "jose": "^5.10.0",
    "pdfkit": "^0.15.2",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
