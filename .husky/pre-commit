#!/usr/bin/env sh

# Secret scanning. Fail closed: contributors must have gitleaks installed.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "ERROR: gitleaks is required for the pre-commit hook." >&2
  echo "  macOS:  brew install gitleaks" >&2
  echo "  others: https://github.com/gitleaks/gitleaks#installing" >&2
  exit 1
fi

gitleaks git --staged --no-banner --redact -v
